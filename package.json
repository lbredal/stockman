{
  "name": "stockman",
  "version": "0.1.0",
  "description": "Lightweight inventory management for small producers",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server.js",
    "test": "vitest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-stringify": "^6.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "pg": "^8.11.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^8.2.2",
    "supertest": "^7.0.0",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  }
}
